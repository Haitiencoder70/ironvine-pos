STRIPE_WEBHOOK_SECRET=whsec_YOUR_SECRET_HERE
RESEND_API_KEY=re_YOUR_KEY_HERE
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173

# Frontend (copy to frontend/.env)
